# Fibonacci – demonstrates recursion and type-checked arithmetic

func fibonacci(n: int) -> int {
    if n <= 1 {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

func main() -> void {
    let i: int = 0
    while i < 10 {
        print(fibonacci(i))
        i = i + 1
    }
}
